generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  feishuUserId String?  @unique
  avatarUrl    String?
  role         String   @default("editor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scripts      Script[]
  tasks        AnalysisTask[]
}

model Script {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  title         String
  source        String   @default("upload")
  filePath      String
  wordCount     Int      @default(0)
  parsedContent Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks         AnalysisTask[]

  @@index([userId])
}

model AnalysisTask {
  id            String    @id @default(cuid())
  scriptId      String
  script        Script    @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  type          String
  status        String    @default("pending")
  promptVersion String
  errorMessage  String?

  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  report        AnalysisReport?

  @@index([scriptId])
  @@index([status])
}

model AnalysisReport {
  id           String       @id @default(cuid())
  taskId       String       @unique
  task         AnalysisTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  summary      String
  overallScore Int?
  issues       Json
  rawResponse  String       @db.Text
  costTokens   Int          @default(0)

  createdAt    DateTime     @default(now())

  feedbacks    IssueFeedback[]
}

// 报告里某一条 issue 的一次反馈,或整份报告的一次反馈(issueIndex=null)
// missing 类型:代表编辑觉得"漏了",note 里写他觉得应该指出的问题
model IssueFeedback {
  id         String         @id @default(cuid())
  reportId   String
  report     AnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  issueIndex Int?           // 对应 report.issues[].issues[issueIndex],null 表示"整份报告级"或"missing"
  vote       String         // useful | useless | missing
  note       String?        @db.Text

  createdAt  DateTime       @default(now())

  @@index([reportId])
  @@index([vote])
}

model PromptTemplate {
  id        String   @id @default(cuid())
  type      String
  version   String
  content   String   @db.Text
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, version])
  @@index([type, isActive])
}
